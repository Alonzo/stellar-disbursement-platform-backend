# Old artifacts (don't commit these)
*.log
security-audit-*/

# Local-only files (keep local, never commit)
# Use wildcards to avoid exposing specific file names
.github/workflows/*.md
.github/workflows/*.sh
*.md
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!LICENSE

# OS files
.DS_Store
*.swp
*~
.vscode/
.idea/

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work

# Temporary files
*.tmp
*.bak
*.backup

# Environment files
.env
.env.local
.env.*.local

# Build artifacts
dist/
build/
bin/

# Test coverage
*.out
coverage.html

# Helm
*.tgz
.helm/

# Kubernetes
*.kubeconfig
